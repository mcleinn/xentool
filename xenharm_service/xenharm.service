[Unit]
Description=XenHarm note name service (used by xentool's Live HUD)
After=network.target

[Service]
Type=simple
# Reference template. `install-systemd.sh` writes a concrete unit with the
# correct absolute paths into ~/.config/systemd/user/xenharm.service.
ExecStart=/usr/bin/env python3.12 /path/to/xentool/xenharm_service/server.py --host 127.0.0.1 --port 3199
WorkingDirectory=/path/to/xentool/xenharm_service
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
